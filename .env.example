NEXT_PUBLIC_DOC_URL=https://docs.canvas.best

# ── 商业化后端（web/ 下的服务端，仅服务端读取，勿加 NEXT_PUBLIC_ 前缀）──
# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/infinite_canvas
# Redis（会话/限流/幂等/锁 + 生成队列/事件总线）。生产强制真实供给，缺失即启动失败（禁止内存回退）。
REDIS_URL=redis://127.0.0.1:6379

# ── 图片生成异步队列 / worker 并发（web 入队、worker 消费共用）──
IMAGE_QUEUE_NAME=image-generation
IMAGE_WORKER_CONCURRENCY=8
IMAGE_USER_CONCURRENCY=2
IMAGE_CHANNEL_CONCURRENCY=4
IMAGE_JOB_ATTEMPTS=3
IMAGE_JOB_BACKOFF_MS=3000
IMAGE_EVENT_HEARTBEAT_MS=25000

# ── WebSocket 事件网关（独立进程）──
# 网关监听端口；生产由反向代理把 /api/generate/events 透传到该端口（需透传 Upgrade/Connection 头）。
WS_PORT=3001
# 前端 WebSocket 连接地址。留空=同源 /api/generate/events（生产走反代）；
# 本地无反代时直连网关端口，例如 ws://localhost:3001/api/generate/events
NEXT_PUBLIC_GENERATE_WS_URL=

# 会话
SESSION_COOKIE_NAME=ic_session
SESSION_TTL_DAYS=30
# 新用户注册赠送算力点
SIGNUP_BONUS_CREDITS=100
# 加密上游 AI Key 用的密钥（32 字节，建议 `openssl rand -hex 32`）
DATA_ENCRYPTION_KEY=

# Cloudflare R2（S3 兼容）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=infinite-canvas
# 绑定的公开访问域（自定义域或 r2.dev）；留空则用预签名 URL（1 小时过期，生产强烈建议配公开域）
R2_PUBLIC_BASE=

# 对账 cron 内部密钥：reconcile 接口可凭此 header 免管理员会话调用
INTERNAL_CRON_KEY=
