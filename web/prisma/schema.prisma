// 无限画布 · 商业化数据模型
// 约定：金额/算力点一律用整数（最小单位），禁止浮点。
// 项目未上线，不兼容旧数据，可直接按新设计建表。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 用户（首发仅邮箱 + 密码登录）────────────────────────────────
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  username      String     @unique
  passwordHash  String
  status        UserStatus @default(active)
  role          Role       @default(user)
  creditBalance Int        @default(0) // 冗余余额，真值以账本最新一行 balance 为准
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sessions    Session[]
  ledgers     CreditLedger[]
  generations GenerationRecord[]

  @@index([createdAt])
}

enum UserStatus {
  active
  banned
}

enum Role {
  user
  admin
  superadmin
}

// 注：Linux.do / 第三方 OAuth 延后，本期不建 OAuthAccount 表。

// ── 会话（DB 表便于后台「踢下线」）───────────────────────────────
model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ── 算力点账本（append-only，所有增减都记一笔）──────────────────
model CreditLedger {
  id        String       @id @default(cuid())
  userId    String
  delta     Int // 正=充值/退点，负=消费
  balance   Int // 本次操作后的余额快照
  reason    LedgerReason
  refType   String?
  refId     String?
  remark    String?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum LedgerReason {
  redeem
  generate
  refund
  admin_adjust
  signup_bonus
}

// ── 兑换码 ──────────────────────────────────────────────────────
model RedemptionCode {
  id        String     @id @default(cuid())
  codeHash  String     @unique // 存哈希，不存明文
  credits   Int
  batchId   String?
  status    CodeStatus @default(unused)
  usedBy    String?
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime   @default(now())

  @@index([batchId])
  @@index([status])
}

enum CodeStatus {
  unused
  used
  disabled
}

// ── 模型计价表（后台可配，按分辨率档位计费）──────────────────────
model ModelPricing {
  id          String   @id @default(cuid())
  channel     String
  model       String
  capability  String // image / video / audio / text
  sizeTier    SizeTier // 图片: t1k/t2k/t4k；视频/音频/文本: standard
  creditsCost Int
  enabled     Boolean  @default(true)

  @@unique([channel, model, capability, sizeTier])
}

// 分辨率档位：图片按长边/总像素归档
//   t1k ≤ ~1024 边长(≈1MP)，t2k ≤ ~2048(≈4MP)，t4k ≤ ~4096(≈16MP)
// standard 给视频/音频/文本占位
enum SizeTier {
  t1k
  t2k
  t4k
  standard
}

// ── 生成记录（落库 + 可审计 + 图库来源）─────────────────────────
model GenerationRecord {
  id          String    @id @default(cuid())
  userId      String
  channel     String
  model       String
  capability  String
  sizeTier    SizeTier  @default(standard)
  prompt      String
  params      Json
  status      GenStatus @default(pending)
  creditsHeld Int       @default(0) // 预扣点数
  creditsCost Int       @default(0) // 实际结算点数
  outputs     Json? // 对象存储 key 列表
  errorMsg    String?
  upstreamId  String?
  // ── 异步队列元信息（入队/执行排障用）──
  jobId           String? // BullMQ job id，取值 = record.id 以保证入队幂等
  clientRequestId String? // 前端 slotId，WebSocket 事件精准匹配 slot
  startedAt       DateTime? // worker 开始处理时间
  finishedAt      DateTime? // 终态（success/failed）落定时间
  retryCount      Int       @default(0) // worker 重试次数
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

enum GenStatus {
  pending // 已建记录、已预扣、已入队（或等待入队）
  running // worker 已开始处理
  success // 生成完成并已落对象存储
  failed // 生成失败终态（已退点）
}

// ── 上游渠道与平台 Key（后台配置，Key 加密存储）─────────────────
model AiChannel {
  id        String  @id @default(cuid())
  name      String
  type      String // openai / gemini / volcengine
  baseUrl   String
  apiKeyEnc String // AES-GCM 加密后的 Key，禁止明文
  weight    Int     @default(1)
  enabled   Boolean @default(true)
}

// ── 审计日志（后台敏感操作留痕）──────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  target    String?
  detail    Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
}
